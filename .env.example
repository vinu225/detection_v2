# ─────────────────────────────────────────────
# News API Keys
# ─────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_key_here

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/news_detection

# ─────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ─────────────────────────────────────────────
# Scraping Settings
# ─────────────────────────────────────────────
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RATE_LIMIT_DELAY=1.0

# ─────────────────────────────────────────────
# RSS Feeds (comma-separated)
# ─────────────────────────────────────────────
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml,https://feeds.reuters.com/reuters/topNews
